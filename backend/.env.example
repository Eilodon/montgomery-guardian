# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/montgomery_guardian

# Redis Configuration
REDIS_URL=redis://localhost:6379

# External APIs
BRIGHT_DATA_API_TOKEN=your_bright_data_token_here

# API Settings
API_TITLE=Montgomery Guardian API
API_VERSION=1.0.0

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# ETL Settings
ETL_INTERVAL_MINUTES=60
MAX_RECORDS_PER_FETCH=2000

# ArcGIS API Settings
ARCGIS_API_TIMEOUT=30

# AI Agents Service URL
AI_AGENTS_URL=http://localhost:3001
